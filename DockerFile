# Use official Node image
FROM node:18

# Set working directory
WORKDIR /app

# Copy all files
COPY . .

# Install backend dependencies
WORKDIR /app/backend
RUN npm install

# Install frontend dependencies and build
WORKDIR /app/frontend
RUN npm install
RUN npm run build

# Go back to root
WORKDIR /app

# Expose port
EXPOSE 8080

# Start backend server
CMD ["node", "backend/server.js"]